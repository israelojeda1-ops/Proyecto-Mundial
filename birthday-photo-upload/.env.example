# Pega aquí el contenido completo del archivo JSON de la cuenta de servicio de Google
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...", "...": "..."}

# ID de la carpeta de Google Drive donde quieres que se guarden las fotos
# (lo encuentras en la URL de la carpeta: drive.google.com/drive/folders/ESTE_ES_EL_ID)
DRIVE_FOLDER_ID=

# Opcional: si quieres pedir un PIN antes de subir fotos (déjalo vacío para no usarlo)
EVENT_PIN=

# Opcional: puerto del servidor (por defecto 3000)
PORT=3000
